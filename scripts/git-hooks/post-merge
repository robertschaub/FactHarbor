#!/usr/bin/env bash
# post-merge — full index rebuild after git pull / merge.
# Covers handoff and pipeline changes pulled from remote.
# Install: cp scripts/git-hooks/post-merge .git/hooks/post-merge && chmod +x .git/hooks/post-merge
# Or run: npm run install-hooks

set -e

REPO_ROOT="$(git rev-parse --show-toplevel)"
INDEX_SCRIPT="$REPO_ROOT/scripts/build-index.mjs"
LOG_FILE="$REPO_ROOT/.git/hooks/factharbor-index.log"

[ -f "$INDEX_SCRIPT" ] || exit 0

printf '[%s] post-merge: build-index full rebuild\n' "$(date -u +"%Y-%m-%dT%H:%M:%SZ")" >> "$LOG_FILE"
node "$INDEX_SCRIPT" >> "$LOG_FILE" 2>&1 || printf '[%s] post-merge: build-index failed\n' "$(date -u +"%Y-%m-%dT%H:%M:%SZ")" >> "$LOG_FILE"

exit 0
