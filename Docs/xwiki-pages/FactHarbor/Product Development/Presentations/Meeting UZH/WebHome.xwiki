== AKEL (AI Knowledge Extraction Layer) Pipeline ==


{{mermaid}}
flowchart TB
    INPUT(["User Input\n(text or URL)"])

    subgraph PIPELINE[" "]
        direction TB
        subgraph STAGE1["1. Extract Claims"]
            direction LR
            PASS1["Pass 1 rough claim scan\n[LLM]"]
            PRESEARCH["Preliminary web grounding\n[Web Search]"]
            PASS2["Pass 2 grounded claims\n[LLM]"]
            CENTRALITY["Centrality filter"]
            GATE1{{"Gate 1\nClaim Validation\n[LLM]"}}
            PASS1 --> PRESEARCH --> PASS2 --> CENTRALITY --> GATE1
        end

        STAGE1 -->|"AtomicClaims"| STAGE2

        subgraph STAGE2["2. Research Evidence"]
            direction LR
            QUERY["Generate pro/con\nsearch queries\n[LLM]"]
            SEARCH["Web search\n[Web Search]"]
            RELEVANCE["Relevance screening\n[LLM]"]
            FETCH["Fetch & parse sources\n[Web Search]"]
            EXTRACT["Extract evidence + scopes\n[LLM]"]
            FILTER["Filter evidence\n(probativeValue)"]
            QUERY --> SEARCH --> RELEVANCE --> FETCH --> EXTRACT --> FILTER
            FILTER -.->|"sufficiency check"| QUERY
        end

        STAGE2 -->|"EvidenceItems + sources"| STAGE3

        subgraph STAGE3["3. Cluster Boundaries"]
            direction LR
            SCOPES["Collect EvidenceScopes\n(methodology, temporal)"]
            NORMALIZE["Normalize equivalent scopes\n[LLM, optional]"]
            CLUSTER["Cluster into emergent\nClaimAssessmentBoundaries\n[LLM]"]
            SCOPES --> NORMALIZE --> CLUSTER
        end

        STAGE3 -->|"ClaimBoundaries +\nCoverageMatrix"| STAGE4

        subgraph STAGE4["4. Generate Verdicts"]
            direction LR
            DEBATE2["LLM Debate Pattern\n[LLM]\n(Advocate/Challenger/Reconciler)"]
            STABILITY["Self-consistency\n[LLM]\n(stability measurement)"]
            VALIDATION["Validator checks\n[LLM]\n(grounding + direction, advisory)"]
            GATE4{{"Gate 4\nConfidence Tiering"}}
            DEBATE2 --> STABILITY --> VALIDATION --> GATE4
        end

        STAGE4 -->|"ClaimVerdicts"| STAGE5

        subgraph STAGE5["5. Aggregate & Report"]
            direction LR
            TRIANG["Triangulation & Weighted\nAggregation"]
            REPORT["Structured Report\n[LLM]\n(Narrative & Findings)"]
            TRIANG --> REPORT
        end
    end

    INPUT -->|"Input text / URL content"| STAGE1
    STAGE5 -->|"OverallAssessment +\nreport"| RESULT(["AnalysisResult\n(schema 3.2.0-cb)"])

    style PIPELINE fill:none,stroke:none
    style INPUT fill:#2196F3,stroke:#1565C0,color:#fff,stroke-width:2px
    style RESULT fill:#4CAF50,stroke:#2E7D32,color:#fff,stroke-width:2px
    style STAGE1 fill:#f3fbf4,stroke:#7cb889,color:#000
