    subgraph NETWORK["Independent Organizations"]
        direction LR

        subgraph ORG1["Organization A"]
            direction TB
            U1["Local Users"] --> FH1["FactHarbor Instance 1"]
        end

        subgraph ORG2["Organization B"]
            direction TB
            U2["Local Users"] --> FH2["FactHarbor Instance 2"]
        end

        subgraph ORG3["Organization C"]
            direction TB
            U3["Local Users"] --> FH3["FactHarbor Instance 3"]
        end
    end

    FH1 -. "claim + verdict sync" .-> PROTOCOL
    FH2 -. "claim + verdict sync" .-> PROTOCOL
    FH3 -. "claim + verdict sync" .-> PROTOCOL

    style PROTOCOL fill:#f3e5f5,stroke:#7b1fa2,color:#000,stroke-width:2px
    style NETWORK fill:#fafafa,stroke:#cfcfcf,color:#000
