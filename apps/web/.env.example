# FactHarbor Environment Variables
# These values must match the API configuration in appsettings.Development.json

# =============================================================================
# IMPORTANT: Agents and Administrators: .env.example shall always be in sync with .env.local, 
# but .env.example without the API Keys!!
# So that Agents that don't have access to .env.local know the current configuration
# =============================================================================

# =============================================================================
# API Configuration
# =============================================================================
FH_API_BASE_URL=http://localhost:5000

# Keys for internal calls (must match API's appsettings.Development.json)
FH_ADMIN_KEY=DEV_SHARED_SECRET_ADMIN_KEY
FH_INTERNAL_RUNNER_KEY=DEV_SHARED_SECRET_RUNNER_KEY

# Legacy shared fallback for runner concurrency.
# If FH_RUNNER_JOB_MAX_CONCURRENCY is unset, this value is used for the report-job lane.
FH_RUNNER_MAX_CONCURRENCY=1
# Optional explicit split lanes:
# FH_RUNNER_JOB_MAX_CONCURRENCY=1
# FH_RUNNER_PREP_MAX_CONCURRENCY=1

# LLM provider backpressure controls for analyzer runtime.
# FH_LLM_MAX_CONCURRENCY_ANTHROPIC=2
# FH_LLM_RETRY_ATTEMPTS=1
# FH_LLM_RETRY_BASE_DELAY_MS=1500

# API rate limit tuning (optional; defaults in API are read=120/min, analyze=5/min)
# FH_READ_PER_IP_PER_MIN=120
# FH_ANALYZE_PER_IP_PER_MIN=5

# Optional: header name set by a trusted reverse proxy with the real client IP.
# Do not point this at a public client-controlled header unless the proxy strips
# inbound copies before setting it.
# FH_TRUSTED_CLIENT_IP_HEADER=x-fh-client-ip

# =============================================================================
# LLM Provider Configuration
# =============================================================================
# API Keys - set the key for your chosen provider
OPENAI_API_KEY=PASTE_YOUR_KEY_HERE
ANTHROPIC_API_KEY=PASTE_YOUR_KEY_HERE
GOOGLE_GENERATIVE_AI_API_KEY=PASTE_YOUR_KEY_HERE
MISTRAL_API_KEY=PASTE_YOUR_KEY_HERE

# =============================================================================
# Web Search Configuration
# =============================================================================
# Search provider/behavior is configured in UCM (Admin -> Config -> Web Search).
# Provider API keys are still required.

# Google Custom Search Engine (recommended - faster, cheaper)
GOOGLE_CSE_API_KEY=PASTE_YOUR_KEY_HERE
GOOGLE_CSE_ID=PASTE_YOUR_CSE_ID_HERE
# Fallbacks
SERPER_API_KEY=PASTE_YOUR_KEY_HERE
BRAVE_API_KEY=PASTE_YOUR_KEY_HERE
SERPAPI_API_KEY=PASTE_YOUR_KEY_HERE

# Note: Wikipedia requires no API key

# Semantic Scholar (academic papers, free key — request at semanticscholar.org/product/api)
# SEMANTIC_SCHOLAR_API_KEY=PASTE_YOUR_KEY_HERE

# Google Fact Check Tools (free — enable in Google Cloud Console)
# GOOGLE_FACTCHECK_API_KEY=PASTE_YOUR_KEY_HERE

# =============================================================================
# Debug Options (development only)
# =============================================================================
# Calibration lane override for report metadata.
# Only used by calibration test scripts; valid values: smoke | gate.
# FH_CALIBRATION_RUN_INTENT=smoke

# Enable debug logging to file (shows detailed analysis decisions)
# FH_DEBUG_LOG_FILE=true  # (default: true - uncomment only to disable)
FH_DEBUG_LOG_PATH=./debug-analyzer.log
# FH_DEBUG_LOG_CLEAR_ON_START=false  # (default: false)

# =============================================================================
# Source Reliability
# =============================================================================
# SR behavior is configured in UCM (Admin -> Config -> Source Reliability).
# Cache storage path remains an env var.
FH_SR_CACHE_PATH=./source-reliability.db
